{
    "index": "/index.html",
    "assetGroups": [
      {
        "name": "mtcorp-app",
        "installMode": "prefetch",
        "resources": {
          "files": [
            "/favicon.ico",
            "/index.html",
            "/*.css",
            "/*.js"
          ]
        }
      },
      {
        "name": "assets",
        "installMode": "lazy",
        "updateMode": "prefetch",
        "resources": {
          "files": [
            "/assets/**",
            "/*.(png|jpg|jpeg|gif|webp|svg)",
            "/*.json"
          ]
        }
      }
    ]
  }
  